#!/bin/bash
#
# Installs httpd and unzip
# Downloads an HTML template
# Deploys it to Apache web root
# Restarts httpd
#

set -Eeuo pipefail

############################
# Configuration
############################
TEMPLATE_URL="https://too-late.com/template.zip"
WEB_ROOT="/var/www/html"
TMP_DIR="/tmp/web_template"
LOG_FILE="/var/log/httpd_template_install.log"

############################
# Helper Functions
############################
log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') | $1" | tee -a "$LOG_FILE"
}

error_exit() {
  log "ERROR: $1"
  exit 1
}

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT

############################
# Pre-flight Checks
############################
[[ $EUID -eq 0 ]] || error_exit "This script must be run as root."

command -v yum >/dev/null || error_exit "yum package manager not found."
command -v curl >/dev/null || error_exit "curl is required but not installed."

############################
# Main Execution
############################
log "Starting HTTPD + template installation"

log "Updating system packages..."
yum -y update >> "$LOG_FILE" 2>&1 || error_exit "System update failed."

log "Installing httpd and unzip..."
yum -y install httpd unzip >> "$LOG_FILE" 2>&1 || error_exit "Package installation failed."

log "Enabling and starting httpd..."
systemctl enable httpd >> "$LOG_FILE" 2>&1
systemctl start httpd || error_exit "Failed to start httpd."

log "Preparing temporary workspace..."
mkdir -p "$TMP_DIR"

log "Downloading HTML template..."
curl -fL "$TEMPLATE_URL" -o "$TMP_DIR/template.zip" \
  >> "$LOG_FILE" 2>&1 || error_exit "Template download failed."

log "Validating ZIP archive..."
unzip -tq "$TMP_DIR/template.zip" >> "$LOG_FILE" 2>&1 \
  || error_exit "Invalid ZIP archive."

log "Extracting template..."
unzip -oq "$TMP_DIR/template.zip" -d "$TMP_DIR" \
  >> "$LOG_FILE" 2>&1 || error_exit "Template extraction failed."

log "Deploying template to web root..."
[[ -d "$WEB_ROOT" ]] || error_exit "Web root does not exist."

rm -rf "${WEB_ROOT:?}"/*
cp -r "$TMP_DIR"/* "$WEB_ROOT"/ || error_exit "Failed to copy template files."

log "Setting ownership and permissions..."
chown -R apache:apache "$WEB_ROOT"
chmod -R 755 "$WEB_ROOT"

log "Restarting httpd..."
systemctl restart httpd || error_exit "httpd restart failed."

log "✅ Installation and deployment completed successfully!"



